# QuantumVault Environment Configuration
# Copy to .env and fill in values

# ------------------------------------------------------------------ #
#  Server Configuration                                                 #
# ------------------------------------------------------------------ #
PORT=8000
HOST=0.0.0.0
DEBUG=true
RELOAD=true

# ------------------------------------------------------------------ #
#  API Security (production)                                            #
# ------------------------------------------------------------------ #
API_SECRET_KEY=your_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------------ #
#  CORS (set to your frontend domain in production)                    #
# ------------------------------------------------------------------ #
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ------------------------------------------------------------------ #
#  Database (for persistent KMS — optional)                             #
# ------------------------------------------------------------------ #
# DATABASE_URL=postgresql://user:password@localhost:5432/quantumvault
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------ #
#  Stripe Billing (for SaaS monetization)                              #
# ------------------------------------------------------------------ #
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------ #
#  QKD Hardware Integration (optional — real hardware)                 #
# ------------------------------------------------------------------ #
# IDQ_CLAVIS_HOST=192.168.1.100
# IDQ_CLAVIS_PORT=8080
# IDQ_API_KEY=your_api_key

# TOSHIBA_QKD_HOST=192.168.1.101
# TOSHIBA_QKD_PORT=8081

# ------------------------------------------------------------------ #
#  ETSI KMS Configuration                                               #
# ------------------------------------------------------------------ #
KMS_MASTER_SAE_ID=quantumvault_kms_master_01
KMS_SLAVE_SAE_ID=quantumvault_kms_slave_01
KMS_DEFAULT_KEY_SIZE_BITS=256
KMS_DEFAULT_TTL_SECONDS=3600
KMS_MAX_STORE_SIZE=100000

# ------------------------------------------------------------------ #
#  Logging                                                              #
# ------------------------------------------------------------------ #
LOG_LEVEL=INFO
LOG_FORMAT=json
